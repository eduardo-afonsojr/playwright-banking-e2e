{
  "info": {
    "_postman_id": "9f1c1a52-4a1a-4a5e-9a7e-banking-e2e",
    "name": "Mini Bank API",
    "description": "API tests for the Mini Bank demo app, run via Newman.\n\nConventions:\n- The automatic cookie jar is disabled on every request (protocolProfileBehavior.disableCookies), so authentication is always explicit: the login request stores the session token in a collection variable and authenticated requests send it in a Cookie header. This keeps the unauthenticated 401 tests deterministic regardless of request order.\n- The run assumes a freshly seeded database (`npm run seed`); `npm run test:api` does this automatically. Counts and balances asserted here derive from the seed state plus the single successful transfer this collection performs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "sessionToken", "value": "" },
    { "key": "checkingAccountId", "value": "" },
    { "key": "savingsAccountId", "value": "" },
    { "key": "checkingBalance", "value": "" },
    { "key": "savingsBalance", "value": "" },
    { "key": "transferAmount", "value": "25" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login — missing fields",
          "protocolProfileBehavior": { "disableCookies": true },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"explains what is required\", function () {",
                  "    pm.expect(pm.response.json().error).to.eql(\"Username and password are required.\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login — invalid credentials",
          "protocolProfileBehavior": { "disableCookies": true },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"does not set a session cookie\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Set-Cookie\")).to.be.oneOf([null, undefined]);",
                  "});",
                  "",
                  "pm.test(\"uses the same message as an unknown user (no enumeration)\", function () {",
                  "    pm.expect(pm.response.json().error).to.eql(\"Invalid username or password.\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"jane.doe\", \"password\": \"wrong-password\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login — valid credentials",
          "protocolProfileBehavior": { "disableCookies": true },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"returns the user profile\", function () {",
                  "    const user = pm.response.json().user;",
                  "    pm.expect(user.username).to.eql(\"jane.doe\");",
                  "    pm.expect(user.fullName).to.eql(\"Jane Doe\");",
                  "});",
                  "",
                  "pm.test(\"sets an httpOnly session cookie\", function () {",
                  "    const setCookie = pm.response.headers.get(\"Set-Cookie\");",
                  "    pm.expect(setCookie).to.include(\"session_token=\");",
                  "    pm.expect(setCookie.toLowerCase()).to.include(\"httponly\");",
                  "",
                  "    // Store the token: every authenticated request sends it explicitly.",
                  "    const token = /session_token=([^;]+)/.exec(setCookie)[1];",
                  "    pm.collectionVariables.set(\"sessionToken\", token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"jane.doe\", \"password\": \"Password123!\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
