        {
          "name": "Transfer — success",
          "protocolProfileBehavior": { "disableCookies": true },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"debits and credits the exact amount\", function () {",
                  "    const amount = Number(pm.collectionVariables.get(\"transferAmount\"));",
                  "    const before = {",
                  "        checking: Number(pm.collectionVariables.get(\"checkingBalance\")),",
                  "        savings: Number(pm.collectionVariables.get(\"savingsBalance\"))",
                  "    };",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.fromAccount.balance).to.eql(before.checking - amount);",
                  "    pm.expect(body.toAccount.balance).to.eql(before.savings + amount);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "session_token={{sessionToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"fromAccountId\": \"{{checkingAccountId}}\", \"toAccountId\": \"{{savingsAccountId}}\", \"amount\": {{transferAmount}}}"
