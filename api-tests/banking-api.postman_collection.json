        {
          "name": "Transactions — filter by date range",
          "protocolProfileBehavior": { "disableCookies": true },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// [30 days ago, yesterday] excludes both the 35-day-old seeded",
                  "// transfer and the pair created by this run (dated today).",
                  "function isoDaysAgo(days) {",
                  "    const d = new Date();",
                  "    d.setDate(d.getDate() - days);",
                  "    return d.toISOString().slice(0, 10);",
                  "}",
                  "pm.collectionVariables.set(\"fromDate\", isoDaysAgo(30));",
                  "pm.collectionVariables.set(\"toDate\", isoDaysAgo(1));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"returns only entries inside the range\", function () {",
                  "    const transactions = pm.response.json().transactions;",
                  "    const from = pm.collectionVariables.get(\"fromDate\");",
                  "    const to = pm.collectionVariables.get(\"toDate\");",
                  "    // Seeded transfers at 28, 20, 14, 7 and 2 days ago → 5 pairs.",
                  "    pm.expect(transactions).to.have.lengthOf(10);",
                  "    transactions.forEach(t => {",
                  "        const day = t.createdAt.slice(0, 10);",
                  "        pm.expect(day >= from && day <= to, `${day} within [${from}, ${to}]`).to.be.true;",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "session_token={{sessionToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/transactions?from={{fromDate}}&to={{toDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "from", "value": "{{fromDate}}" },
                { "key": "to", "value": "{{toDate}}" }
              ]
            }
          }
        },
