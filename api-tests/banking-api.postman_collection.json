            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"]
            }
          }
        },
        {
          "name": "Accounts — authenticated",
          "protocolProfileBehavior": { "disableCookies": true },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const accounts = pm.response.json().accounts;",
                  "",
                  "pm.test(\"returns the two seeded accounts\", function () {",
                  "    pm.expect(accounts).to.have.lengthOf(2);",
                  "    const names = accounts.map(a => a.name).sort();",
                  "    pm.expect(names).to.eql([\"Checking\", \"Savings\"]);",
                  "});",
                  "",
                  "pm.test(\"serializes accounts without leaking Mongo internals\", function () {",
                  "    accounts.forEach(account => {",
                  "        pm.expect(account.id).to.be.a(\"string\");",
                  "        pm.expect(account.balance).to.be.a(\"number\");",
                  "        pm.expect(account.currency).to.eql(\"USD\");",
                  "        pm.expect(account).to.not.have.property(\"_id\");",
                  "        pm.expect(account).to.not.have.property(\"userId\");",
                  "    });",
                  "});",
                  "",
                  "// Stash ids and balances for the transfer tests (delta assertions).",
                  "const checking = accounts.find(a => a.name === \"Checking\");",
                  "const savings = accounts.find(a => a.name === \"Savings\");",
                  "pm.collectionVariables.set(\"checkingAccountId\", checking.id);",
                  "pm.collectionVariables.set(\"savingsAccountId\", savings.id);",
                  "pm.collectionVariables.set(\"checkingBalance\", checking.balance);",
                  "pm.collectionVariables.set(\"savingsBalance\", savings.balance);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "session_token={{sessionToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "accounts"]
            }
          }
        }
      ]
