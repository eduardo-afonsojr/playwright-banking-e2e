          "protocolProfileBehavior": { "disableCookies": true },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const transactions = pm.response.json().transactions;",
                  "",
                  "pm.test(\"contains the 12 seeded entries plus the pair from this run's transfer\", function () {",
                  "    pm.expect(transactions).to.have.lengthOf(14);",
                  "});",
                  "",
                  "pm.test(\"is sorted newest first\", function () {",
                  "    const dates = transactions.map(t => t.createdAt);",
                  "    const sorted = [...dates].sort().reverse();",
                  "    pm.expect(dates).to.eql(sorted);",
                  "});",
                  "",
                  "pm.test(\"every entry has the serialized shape\", function () {",
                  "    transactions.forEach(t => {",
                  "        pm.expect(t.id).to.be.a(\"string\");",
                  "        pm.expect(t.accountId).to.be.a(\"string\");",
                  "        pm.expect([\"transfer_in\", \"transfer_out\"]).to.include(t.type);",
                  "        pm.expect(t.amount).to.be.a(\"number\");",
                  "        pm.expect(t.createdAt).to.match(/^\\d{4}-\\d{2}-\\d{2}T/);",
                  "    });",
                  "});"
                ]
              }
            }
          ],
